APP_NAME="Pontius CRM"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Mexico_City
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_MX

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pontius_crm
DB_USERNAME=root
DB_PASSWORD=

# ============================================
# SESSION CONFIGURATION
# ============================================
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ============================================
# BROADCAST & FILESYSTEM & QUEUE
# ============================================
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# ============================================
# CACHE CONFIGURATION
# ============================================
CACHE_DRIVER=redis
CACHE_PREFIX=pontius_
CACHE_REDIS_CONNECTION=default

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CACHE_DB=1

# ============================================
# MAIL CONFIGURATION
# ============================================
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_username
MAIL_PASSWORD=your_password
MAIL_FROM_ADDRESS=noreply@pontius.com
MAIL_FROM_NAME="Pontius CRM"

# ============================================
# AWS CONFIGURATION (Optional)
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=base64:change_me_to_generated_secret
JWT_ALGORITHM=HS256
JWT_TTL=60

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# APPLICATION SETTINGS
# ============================================
PAGINATION_DEFAULT=15
MAX_UPLOAD_SIZE=10

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_LEADS=true
FEATURE_DEVELOPMENTS=true
FEATURE_LISTINGS=true
FEATURE_ACTIVITIES=true
FEATURE_REPORTS=true

# ============================================
# THIRD-PARTY SERVICES
# ============================================
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
GOOGLE_ANALYTICS_ID=
SENTRY_LARAVEL_DSN=

# ============================================
# DEBUG MODE (Development Only)
# ============================================
DEBUGBAR_ENABLED=true

VITE_APP_NAME="${APP_NAME}"
